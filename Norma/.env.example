# ============================================
# Norma Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# --------------------------------------------
# Required for app.py
# --------------------------------------------

# Directory containing input data
NORMA_DATA_DIR=D:/Projects/Specora/Norma/data

# Path to FAISS index file
NORMA_INDEX_PATH=D:/Projects/Specora/Norma/data/processed/faiss_index.bin

# Path to chunk metadata JSON
NORMA_META_PATH=D:/Projects/Specora/Norma/data/processed/chunk_metadata.json

# Path to chunks JSON
NORMA_CHUNKS_PATH=D:/Projects/Specora/Norma/data/processed/chunks.json

# Gemini API key for LLM functionality
GEMINI_API_KEY=your_gemini_api_key_here

# --------------------------------------------
# Optional (have defaults)
# --------------------------------------------

# Embedding model name (default: sentence-transformers/all-MiniLM-L6-v2)
NORMA_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Number of top results to retrieve (default: 5)
NORMA_TOP_K=5

# Similarity threshold for retrieval (default: 0.25)
NORMA_SIM_THRESHOLD=0.25

# Path to embeddings numpy file (used by ingest.py)
NORMA_EMB_PATH=D:/Projects/Specora/Norma/data/processed/embeddings.npy

# --------------------------------------------
# Required for preprocessor.py
# --------------------------------------------

# Path to input PDF file
PDF_PATH=D:/Projects/Specora/Norma/data/raw/input.pdf

# Path for preprocessor output
OUTPUT_PATH=D:/Projects/Specora/Norma/data/processed/output.txt
