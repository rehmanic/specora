generator client {
  provider      = "prisma-client-js"
  output        = "../../prisma/generated/client"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model app_user {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username        String           @unique @db.VarChar(100)
  display_name    String?          @db.VarChar(150)
  password_hash   String
  email           String           @unique @db.VarChar(255)
  profile_pic_url String?          @default("https://cdn-icons-png.flaticon.com/128/1077/1077012.png")
  created_at      DateTime?        @default(now()) @db.Timestamptz(6)
  updated_at      DateTime?        @default(now()) @db.Timestamptz(6)
  role_id         String           @db.Uuid
  role            role             @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project         project[]
  project_member  project_member[]
  group_message   group_message[]
  feedback_response feedback_response[]
  organized_meetings meeting[]
  meeting_attendance meeting_attendee[]
}

model feedback {
  id                String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title             String               @unique @db.VarChar(255)
  description       String?
  status            feedback_status_enum
  form_structure    Json
  created_at        DateTime?            @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?            @default(now()) @db.Timestamptz(6)
  project_id        String               @db.Uuid
  project           project              @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  feedback_response feedback_response[]
}

model feedback_response {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  response      Json
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  updated_at    DateTime? @default(now()) @db.Timestamptz(6)
  feedback_id   String    @db.Uuid
  respondent_id String?   @db.Uuid
  feedback      feedback  @relation(fields: [feedback_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  app_user      app_user? @relation(fields: [respondent_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model group_chat {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  project_id    String          @db.Uuid
  project       project         @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  attachments   Json?
  group_message group_message[]
}

model group_message {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  content       String
  metadata      Json?
  created_at    DateTime?  @default(now()) @db.Timestamptz(6)
  group_chat_id String     @db.Uuid
  group_chat    group_chat @relation(fields: [group_chat_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sender_id     String     @db.Uuid
  sender        app_user   @relation(fields: [sender_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model permission {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String            @unique @db.VarChar(100)
  role_permission role_permission[]
}

model project {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String           @unique @db.VarChar(255)
  slug            String           @unique @db.VarChar(255)
  description     String?
  cover_image_url String?          @default("https://images.unsplash.com/photo-1519389950473-47ba0277781c?ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8MTR8fHNvZnR3YXJlfGVufDB8fDB8fHww&auto=format&fit=crop&q=60&w=600")
  icon_url        String?          @default("https://cdn-icons-png.flaticon.com/128/1383/1383970.png")
  status          String?          @default("active") @db.VarChar(50)
  start_date      DateTime         @db.Date
  end_date        DateTime         @db.Date
  tags            String[]         @default([])
  created_at      DateTime?        @default(now()) @db.Timestamptz(6)
  updated_at      DateTime?        @default(now()) @db.Timestamptz(6)
  created_by      String?          @db.Uuid
  feedback        feedback[]
  group_chat      group_chat[]
  app_user        app_user?        @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project_member  project_member[]
  requirement     requirement[]
  specbot_chat    specbot_chat[]
  meetings        meeting[]
  economic_config economic_config?
}

model project_member {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  project_id String   @db.Uuid
  member_id  String   @db.Uuid
  app_user   app_user @relation(fields: [member_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project    project  @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model requirement {
  id          String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String                    @db.VarChar(255)
  description String
  priority    requirement_priority_enum
  status      requirement_status_enum
  created_at  DateTime?                 @default(now()) @db.Timestamptz(6)
  updated_at  DateTime?                 @default(now()) @db.Timestamptz(6)
  project_id  String                    @db.Uuid
  project     project                   @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  economic_estimate economic_estimate?
}

model role {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String            @unique @db.VarChar(100)
  app_user        app_user[]
  role_permission role_permission[]
}

model role_permission {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role_id       String     @db.Uuid
  permission_id String     @db.Uuid
  permission    permission @relation(fields: [permission_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  role          role       @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model specbot_chat {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title           String            @unique @db.VarChar(255)
  created_at      DateTime?         @default(now()) @db.Timestamptz(6)
  updated_at      DateTime?         @default(now()) @db.Timestamptz(6)
  project_id      String            @db.Uuid
  project         project           @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  specbot_message specbot_message[]
}

model specbot_message {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  content         String
  metadata        Json?
  sender_type     sender_type_enum @default(user)
  created_at      DateTime?        @default(now()) @db.Timestamptz(6)
  updated_at      DateTime?        @default(now()) @db.Timestamptz(6)
  specbot_chat_id String           @db.Uuid
  specbot_chat    specbot_chat     @relation(fields: [specbot_chat_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

enum feedback_status_enum {
  created
  sent
  opened
  submitted
  closed
  edited
}

enum requirement_priority_enum {
  low
  mid
  high
}

enum requirement_status_enum {
  approved
  pending
  rejected
}

enum sender_type_enum {
  user
  bot
}

model meeting {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String   @db.VarChar(255)
  description String?
  start_time  DateTime @db.Timestamptz(6)
  end_time    DateTime? @db.Timestamptz(6)
  status      meeting_status_enum @default(scheduled)
  recording_url String?
  
  project_id  String   @db.Uuid
  project     project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  
  created_by  String   @db.Uuid
  organizer   app_user @relation(fields: [created_by], references: [id], onDelete: NoAction)

  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)

  attendees   meeting_attendee[]
  transcripts meeting_transcript[]
}

model meeting_attendee {
  meeting_id String   @db.Uuid
  meeting    meeting  @relation(fields: [meeting_id], references: [id], onDelete: Cascade)
  
  user_id    String   @db.Uuid
  user       app_user @relation(fields: [user_id], references: [id], onDelete: Cascade)

  role       meeting_role_enum @default(participant)
  joined_at  DateTime? @db.Timestamptz(6)
  
  @@id([meeting_id, user_id])
}

model meeting_transcript {
   id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
   meeting_id  String   @db.Uuid
   meeting     meeting  @relation(fields: [meeting_id], references: [id], onDelete: Cascade)
   
   content     String   
   created_at  DateTime @default(now()) @db.Timestamptz(6)
}

enum meeting_status_enum {
  scheduled
  live
  completed
  cancelled
}

enum meeting_role_enum {
   host
   participant
}

model economic_config {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  project_id     String    @unique @db.Uuid
  project        project   @relation(fields: [project_id], references: [id], onDelete: Cascade)
  hourly_rate    Float     @default(50)
  currency       String    @default("USD") @db.VarChar(3)
  num_developers Int       @default(1)
  created_at     DateTime? @default(now()) @db.Timestamptz(6)
  updated_at     DateTime? @default(now()) @db.Timestamptz(6)
}

model economic_estimate {
  id                String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requirement_id    String      @unique @db.Uuid
  requirement       requirement @relation(fields: [requirement_id], references: [id], onDelete: Cascade)
  optimistic_hours  Float
  most_likely_hours Float
  pessimistic_hours Float
  created_at        DateTime?   @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?   @default(now()) @db.Timestamptz(6)
}
