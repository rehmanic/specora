# ========================================
# Specora FYP - Environment Configuration
# ========================================
# 
# IMPORTANT: 
# 1. Copy this file to .env in the same directory
# 2. Update all values marked with <CHANGE_THIS>
# 3. Never commit .env to Git!
# 
# For team setup instructions, see:
# - DATABASE_USER_SETUP.md (local development)
# - README.md (deployment)
#

# ========================================
# Server Configuration
# ========================================
NODE_ENV=development
PORT=5000
API_PREFIX=/api

# ========================================
# PostgreSQL Database Configuration
# ========================================
# RECOMMENDED: Create dedicated 'specora' user (see DATABASE_USER_SETUP.md)
# 
# Local Development:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=specora
DB_USER=specora
DB_PASSWORD=<CHANGE_THIS_specora_dev_2025>
#
# Production (Railway/Render/Supabase):
# DB_HOST=<your-production-host>
# DB_PORT=5432
# DB_NAME=<your-production-db>
# DB_USER=<your-production-user>
# DB_PASSWORD=<your-production-password>

# ========================================
# Frontend URL (for CORS and meeting links)
# ========================================
# Local:
FRONTEND_URL=http://localhost:3000
#
# Production:
# FRONTEND_URL=https://specora.vercel.app

# ========================================
# JWT Authentication
# ========================================
# IMPORTANT: Change this to a random string in production!
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=<CHANGE_THIS_use_random_secret_in_production>
JWT_EXPIRES_IN=7d

# ========================================
# Email Configuration (for notifications)
# ========================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=<CHANGE_THIS_your-team-email@gmail.com>
EMAIL_PASSWORD=<CHANGE_THIS_app_password_from_google>
#
# To get Gmail app password:
# 1. Enable 2FA on your Google account
# 2. Go to: https://myaccount.google.com/apppasswords
# 3. Generate app password
# 4. Use that password here (not your regular password)

# ========================================
# OpenAI API (for AI features - Specbot)
# ========================================
OPENAI_API_KEY=<CHANGE_THIS_your_openai_api_key>
#
# Get your API key from: https://platform.openai.com/api-keys
# Optional: Only needed for AI-powered features
